SELECT AVG(SalePrice) as &quot;avg&quot;, OverallQual FROM train GROUP BY OverallQual;
SELECT id, SalePrice, GrLivArea FROM train ORDER BY SalePrice DESC, GrLivArea ASC;
SELECT Neighborhood, RANK() OVER (ORDER BY AVG(SalePrice) DESC) AS &quot;rank&quot;
FROM train GROUP BY Neighborhood ORDER BY &quot;rank&quot; LIMIT 5;
SELECT Neighborhood, RANK() OVER (ORDER BY AVG(SalePrice) DESC) AS &quot;rank&quot;
FROM train GROUP BY Neighborhood ORDER BY &quot;rank&quot; DESC LIMIT 5;</sql><current_tab id="0"/></tab_sql></sqlb_project>
